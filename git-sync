#!/bin/bash

COMMIT_ID=$1
SOURCE_BRANCH=$2

echo "----------------------------------------"
echo "        Git Sync CLI        "
echo "----------------------------------------"

if [ -z "$COMMIT_ID" ]; then
  echo "Error: Missing commit ID" >&2
  echo "Usage: git-sync <commit-id> [branch]" >&2
  exit 1
fi

CURRENT_BRANCH=$(git branch --show-current)
echo "Current branch: $CURRENT_BRANCH"

# Validate commit
if ! git cat-file -e "$COMMIT_ID^{commit}" 2>/dev/null; then
  echo "Invalid commit: $COMMIT_ID"
  exit 1
fi

# Fetch latest
echo "Fetching latest..."
git fetch origin >/dev/null 2>&1

# Validate branch if provided
if [ -n "$SOURCE_BRANCH" ]; then
  if ! git rev-parse --verify "origin/$SOURCE_BRANCH" >/dev/null 2>&1; then
    echo "Branch not found: $SOURCE_BRANCH"
    exit 1
  fi
  echo "Code source: branch → $SOURCE_BRANCH"
else
  echo "Code source: commit → $COMMIT_ID"
fi

# Get files
FILES=$(git show --name-only --pretty="" "$COMMIT_ID")

if [ -z "$FILES" ]; then
  echo "No files found" >&2
  exit 0
fi

echo "----------------------------------------"
echo "            Processing files            "
echo "----------------------------------------"

COUNT=0
echo "$FILES" | while read -r file; do
  if [ -n "$file" ]; then
    COUNT=$((COUNT + 1))
    echo "$COUNT - $file"

    if [ -n "$SOURCE_BRANCH" ]; then
      git checkout "origin/$SOURCE_BRANCH" -- "$file" 2>/dev/null
    else
      git checkout "$COMMIT_ID" -- "$file" 2>/dev/null
    fi
  fi
done

# Stage
echo "----------------------------------------"
echo "           Staging changes            "
git add .

echo "----------------------------------------"
echo "                Done!                   "
echo "----------------------------------------"
